{
  "name": "vessel",
  "productName": "Vessel",
  "version": "1.0.0",
  "description": "A lightweight, secure Discord wrapper for Linux",
  "main": "main.js",
  "author": {
    "name": "Saurav Sreejith",
    "email": "sauravsreejith2005@gmail.com",
    "url": "https://github.com/SauravSreejith/"
  },
  "license": "MIT",
  "keywords": [
    "discord",
    "linux",
    "electron",
    "wrapper",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SauravSreejith/Vessel.git"
  },
  "scripts": {
    "start": "electron .",
    "start:debug": "ELECTRON_ENABLE_LOGGING=1 electron . --inspect=5858",
    "build": "electron-builder --linux",
    "build:all": "electron-builder --linux --x64 --arm64",
    "dist:deb": "electron-builder --linux deb",
    "dist:appimage": "electron-builder --linux AppImage",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint ."
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vessel.discord",
    "productName": "Vessel",
    "copyright": "Copyright © 2026 Saurav Sreejith",
    "asar": true,
    "asarUnpack": [
      "icons/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "error.html",
      "icons/**",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icons",
      "category": "Network",
      "description": "A lightweight, secure Discord wrapper for Linux",
      "desktop": {
        "Name": "Vessel",
        "Comment": "Discord for Linux",
        "Keywords": "discord;chat;voice;video",
        "StartupWMClass": "vessel"
      }
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libappindicator3-1",
        "libxtst6"
      ]
    },
    "publish": null
  }
}
